# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Base de dados (PostgreSQL via Prisma) ────────────────────────────────────
DATABASE_URL=postgresql://ebooks:ebooks_secret@localhost:5432/ebooks_reading

# ─── MinIO (ficheiros PDF dos ebooks) ────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ebooks_admin
MINIO_SECRET_KEY=ebooks_secret_123
MINIO_BUCKET=ebooks

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://ebooks:ebooks_secret@localhost:5672
